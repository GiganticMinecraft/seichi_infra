FROM busybox:1.38.0 AS srv-stopper-downloader
# renovate: datasource=github-releases depName=giganticminecraft/SrvStopper
ARG SRV_STOPPER_VERSION=1.0.0
RUN wget \
  -O /root/SrvStopper.jar \
  https://github.com/giganticminecraft/SrvStopper/releases/download/v${SRV_STOPPER_VERSION}/SrvStopper-${SRV_STOPPER_VERSION}.jar

FROM ghcr.io/giganticminecraft/seichi_minecraft_server_base:1.0.0-java17-jdk@sha256:3def1a1f4ab585b4a35e4e9c2819cd48de13f3e9f2771fbaf869022a9d33bef4

ENV VERSION="1.18.2"
ENV DIFFICULTY="peaceful"

# SrvStopper.jar を配置
COPY --link --from=srv-stopper-downloader /root/SrvStopper.jar /plugins/SrvStopper.jar

# サーバー自体の設定ファイル
COPY --link ./common-minecraft-server-configs /config

# プラグインの設定ファイル
COPY --link ./additional-plugin-configs /plugins

###
# 環境変数として指定されるべきプラグインの設定
#
ENV CFG_REPLACEMENT__COREPROTECT_MYSQL_DATABASE_NAME=""
ENV CFG_REPLACEMENT__COREPROTECT_MYSQL_HOST=""
ENV CFG_REPLACEMENT__COREPROTECT_MYSQL_PORT=""
ENV CFG_REPLACEMENT__COREPROTECT_MYSQL_USER=""
ENV CFG_REPLACEMENT__COREPROTECT_MYSQL_PASSWORD=""

ENV CFG_REPLACEMENT__LUCKPERMS_SERVER_NAME="lobby"
ENV CFG_REPLACEMENT__LUCKPERMS_MYSQL_HOST=""
ENV CFG_REPLACEMENT__LUCKPERMS_MYSQL_PORT=""
ENV CFG_REPLACEMENT__LUCKPERMS_MYSQL_USER=""
ENV CFG_REPLACEMENT__LUCKPERMS_MYSQL_DATABASE_NAME=""
ENV CFG_REPLACEMENT__LUCKPERMS_MYSQL_PASSWORD=""

ENV CFG_REPLACEMENT__LITEBANS_SERVER_NAME="lobby"
ENV CFG_REPLACEMENT__LITEBANS_MYSQL_HOST=""
ENV CFG_REPLACEMENT__LITEBANS_MYSQL_PORT=""
ENV CFG_REPLACEMENT__LITEBANS_MYSQL_USER=""
ENV CFG_REPLACEMENT__LITEBANS_MYSQL_DATABASE_NAME=""
ENV CFG_REPLACEMENT__LITEBANS_MYSQL_PASSWORD=""

ENV CFG_REPLACEMENT__ANTI_PROXY_API_KEY=""

# e.g. "9225"
ENV CFG_REPLACEMENT__PROMETHEUS_EXPORTER_PORT=""

# originally it was "\\192.168.xxx.xxx\seichi-share\schematics"
ENV CFG_REPLACEMENT__WORLDEDIT_SCHEMATICS_DIRECTORY=""

ENV CFG_REPLACEMENT__DISCORDSRV_MINECRAFT_PLAYER_JOIN_MESSAGE_ENABLED="false"
ENV CFG_REPLACEMENT__DISCORDSRV_MINECRAFT_PLAYER_FIRST_JOIN_MESSAGE_ENABLED="true"
ENV CFG_REPLACEMENT__DISCORDSRV_MINECRAFT_PLAYER_LEAVE_MESSAGE_ENABLED="false"
ENV CFG_REPLACEMENT__DISCORDSRV_MINECRAFT_PLAYER_DEATH_MESSAGE_ENABLED="false"
ENV CFG_REPLACEMENT__DISCORDSRV_MINECRAFT_PLAYER_ACHIEVEMENT_MESSAGE_ENABLED="false"
